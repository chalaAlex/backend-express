{
  "info": {
    "name": "Freight Carrier Request API",
    "description": "Complete API collection for testing freight carrier request feature",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "freight_owner_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "carrier_owner_1_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "carrier_owner_2_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "freight_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "truck_1_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "truck_2_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "request_id_1",
      "value": "",
      "type": "string"
    },
    {
      "key": "request_id_2",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Setup - Create Users",
      "item": [
        {
          "name": "1.1 Create Freight Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('freight_owner_token', response.token);",
                  "    console.log('Freight Owner Token saved:', response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"freightowner@test.com\",\n  \"phone\": \"+251911234567\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "signup"]
            }
          }
        },
        {
          "name": "1.2 Create Carrier Owner 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('carrier_owner_1_token', response.token);",
                  "    console.log('Carrier Owner 1 Token saved:', response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Hassan\",\n  \"email\": \"carrier1@test.com\",\n  \"phone\": \"+251922345678\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\",\n  \"role\": \"carrier_owner\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "signup"]
            }
          }
        },
        {
          "name": "1.3 Create Carrier Owner 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('carrier_owner_2_token', response.token);",
                  "    console.log('Carrier Owner 2 Token saved:', response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Sara\",\n  \"lastName\": \"Tesfaye\",\n  \"email\": \"carrier2@test.com\",\n  \"phone\": \"+251933456789\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\",\n  \"role\": \"carrier_owner\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "signup"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Setup - Create Test Data",
      "item": [
        {
          "name": "2.1 Create Freight",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('freight_id', response.data.freight._id);",
                  "    console.log('Freight ID saved:', response.data.freight._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freight_owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cargo\": {\n    \"type\": \"Electronics\",\n    \"description\": \"Laptops and computer equipment\",\n    \"weightKg\": 5000,\n    \"quantity\": 100\n  },\n  \"route\": {\n    \"pickup\": {\n      \"region\": \"Addis Ababa\",\n      \"city\": \"Addis Ababa\",\n      \"address\": \"Bole, Atlas Building\"\n    },\n    \"dropoff\": {\n      \"region\": \"Oromia\",\n      \"city\": \"Adama\",\n      \"address\": \"Main Street, Tech Hub\"\n    },\n    \"distanceKm\": 100\n  },\n  \"schedule\": {\n    \"pickupDate\": \"2026-03-15T08:00:00.000Z\",\n    \"deliveryDeadline\": \"2026-03-16T18:00:00.000Z\"\n  },\n  \"truckRequirement\": {\n    \"type\": \"BOX\",\n    \"minCapacityKg\": 6000\n  },\n  \"pricing\": {\n    \"type\": \"FIXED\",\n    \"amount\": 15000\n  },\n  \"image\": [\"https://example.com/freight1.jpg\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/freights",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "freights"]
            }
          }
        },
        {
          "name": "2.2 Create Truck 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('truck_1_id', response.data.truck._id);",
                  "    console.log('Truck 1 ID saved:', response.data.truck._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{carrier_owner_1_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Actros 2545\",\n  \"plateNumber\": \"AA-3-12345\",\n  \"brand\": \"Mercedes-Benz\",\n  \"pricePerKm\": 70,\n  \"loadCapacity\": 8000,\n  \"features\": [\"GPS Tracking\", \"Refrigerated\", \"Air Suspension\"],\n  \"location\": \"Addis Ababa\",\n  \"radiusKm\": 500,\n  \"image\": [\"https://example.com/truck1.jpg\"],\n  \"aboutTruck\": \"Premium truck for delicate cargo with temperature control\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/trucks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "trucks"]
            }
          }
        },
        {
          "name": "2.3 Create Truck 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('truck_2_id', response.data.truck._id);",
                  "    console.log('Truck 2 ID saved:', response.data.truck._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{carrier_owner_2_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"Isuzu FTR 90\",\n  \"plateNumber\": \"AA-3-67890\",\n  \"brand\": \"Isuzu\",\n  \"pricePerKm\": 55,\n  \"loadCapacity\": 7000,\n  \"features\": [\"GPS Tracking\", \"Cargo Insurance\"],\n  \"location\": \"Adama\",\n  \"radiusKm\": 400,\n  \"image\": [\"https://example.com/truck2.jpg\"],\n  \"aboutTruck\": \"Reliable truck for general cargo transportation\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/trucks",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "trucks"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Request Operations",
      "item": [
        {
          "name": "3.1 Create Requests (Multiple Carriers)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data.createdRequests.length > 0) {",
                  "        pm.collectionVariables.set('request_id_1', response.data.createdRequests[0]);",
                  "        console.log('Request 1 ID saved:', response.data.createdRequests[0]);",
                  "    }",
                  "    if (response.data.createdRequests.length > 1) {",
                  "        pm.collectionVariables.set('request_id_2', response.data.createdRequests[1]);",
                  "        console.log('Request 2 ID saved:', response.data.createdRequests[1]);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freight_owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"freightId\": \"{{freight_id}}\",\n  \"carrierIds\": [\"{{truck_1_id}}\", \"{{truck_2_id}}\"],\n  \"proposedPrice\": 14000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/requests",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests"]
            }
          }
        },
        {
          "name": "3.2 Test Duplicate Prevention",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freight_owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"freightId\": \"{{freight_id}}\",\n  \"carrierIds\": [\"{{truck_1_id}}\"],\n  \"proposedPrice\": 13000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/requests",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests"]
            }
          }
        },
        {
          "name": "3.3 Get Sent Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freight_owner_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/requests/sent",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests", "sent"]
            }
          }
        },
        {
          "name": "3.4 Get Received Requests (Carrier 1)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{carrier_owner_1_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/requests/received",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests", "received"]
            }
          }
        },
        {
          "name": "3.5 Reject Request (Carrier 2)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{carrier_owner_2_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/requests/{{request_id_2}}/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests", "{{request_id_2}}", "reject"]
            }
          }
        },
        {
          "name": "3.6 Accept Request (Carrier 1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{carrier_owner_1_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/requests/{{request_id_1}}/accept",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests", "{{request_id_1}}", "accept"]
            }
          }
        },
        {
          "name": "3.7 Cancel Request",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freight_owner_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/requests/{{request_id_1}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests", "{{request_id_1}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Error Scenarios",
      "item": [
        {
          "name": "4.1 Unauthorized - Wrong Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{carrier_owner_1_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"freightId\": \"{{freight_id}}\",\n  \"carrierIds\": [\"{{truck_1_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/requests",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests"]
            }
          }
        },
        {
          "name": "4.2 Invalid Freight ID",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freight_owner_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"freightId\": \"000000000000000000000000\",\n  \"carrierIds\": [\"{{truck_1_id}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/requests",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "requests"]
            }
          }
        }
      ]
    }
  ]
}
